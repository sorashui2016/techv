# Explore sources
# Optional. Required only when enabling Vimeo API based exploration.
VIMEO_ACCESS_TOKEN=""
# Optional. Raises GitHub Search API rate limits for explore signals.
GITHUB_TOKEN=""

# Local monitor script
APP_BASE_URL="http://localhost:3000"

# Feishu custom bot webhook. Leave empty to disable push.
FEISHU_WEBHOOK_URL=""
FEISHU_WEBHOOK_SECRET=""
